units metal
atom_style atomic
atom_modify map yes
dimension 3
newton on
boundary p p p

# Read initial structure
read_data ./monoclinic_pdf_refinement_single_crystal_11K.data
replicate 3 4 3

# Convert box to triclinic to allow angle changes
change_box all triclinic

# MACE pair style
pair_style mace no_domain_decomposition
pair_coeff * * fine-tuned_mace-mp-0b3-medium_compiled.model-lammps.pt Ru P
mass 1 101.07
mass 2 30.973761

# Set temperature (modify this value for each job)
variable TEMP equal 10.0

# Initialize velocities
velocity all create ${TEMP} 123456

# Neighbor settings
neighbor 1.0 bin
neigh_modify delay 5 every 1
timestep 0.002

# Thermo output with all lattice information
thermo 25
thermo_style custom step temp press pe ke etotal vol lx ly lz xy xz yz

# CRITICAL: Use triclinic (tri) for fully flexible cell
fix 1 all npt temp ${TEMP} ${TEMP} $(100.0*dt) tri 0.0 0.0 $(1000.0*dt)

# Output lattice parameters every 25 steps
fix lattice_output all print 25 "$(step) $(temp) $(press) $(vol) $(lx) $(ly) $(lz) $(xy) $(xz) $(yz)" &
    file lattice_params.dat screen no

# Dump trajectory (optional - remove if files get too large)
dump myDump all custom 25 trajectory.dump id type x y z
dump_modify myDump sort id

# Restart files
restart 2500 tmp.restart

# Run for 100 ps (50000 steps with 2 fs timestep)
run 50000

# Write final configuration
write_data final_config.data
